# API Configuration
VITE_API_BASE_URL=https://api.example.com
NEXT_PUBLIC_BASE_URL=http://localhost:3000

# HUBSPOT CRM API INTEGRATION
# ============================
# Use ONE of the authentication methods below:

# OPTION 1: Private App (Recommended)
# Create a private app at: Settings > Integrations > Private Apps
# Select the following scopes:
#   - crm.objects.contacts.read
#   - crm.objects.contacts.write
#   - crm.objects.deals.read
#   - crm.objects.deals.write
#   - crm.objects.associations.write
HUBSPOT_ACCESS_TOKEN=your-private-app-access-token

# Account Region (optional)
# ========================
# Set to "eu" if your HubSpot account is in the EU data center
# Default: "us" (US data center)
# Examples: "us", "eu", "eu1"
HUBSPOT_ACCOUNT_REGION=us

# Pipeline and Deal Stage Configuration
# =====================================
# Default pipeline ID: 874236271
# Default dealstage ID: 1310030426
# (These are used when creating new deals)

# OPTION 2: API Key (Legacy)
# Get your API key from: Settings > Integrations > API Key
# HUBSPOT_API_KEY=your-hubspot-api-key
# HUBSPOT_PORTAL_ID=20744123

# OPTION 3: Using Portal ID directly (if you have it configured)
# NEXT_PUBLIC_HUBSPOT_PORTAL_ID=20744123
